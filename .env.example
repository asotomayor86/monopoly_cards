# ---------------------------------------------------------------------------
# Monopoly Deal (Game Hub) — variables de entorno
# Copia este fichero a .env (dev socket.io) y/o .env.local (Vercel/Neon) y ajusta.
# ---------------------------------------------------------------------------

# --- Acceso local (solo backend dev server/, socket.io) ---
# Código de acceso a la web (lo comparte toda la familia para poder entrar)
SITE_ACCESS_CODE=familia2024
# Código del administrador (acceso al panel de salas)
ADMIN_CODE=admin-secreto
# Puerto del servidor dev (sirve API, Socket.IO y, en prod local, el frontend)
PORT=3000

# --- Integración con el Hub familiar de juegos (producción, serverless api/) ---
# URL base del hub (cliente y servidor)
HUB_URL=https://one-page-to-rule-them-all.vercel.app
# Secreto compartido para devolver el resultado al hub (server-to-server).
# El hub valida contra HUB_RESULT_SECRET (o HUB_RESULT_SECRET_2): el MISMO que Assemble.
HUB_RESULT_SECRET=
# Secreto para firmar la cookie de identidad del juego (mc_user). Genera uno propio.
AUTH_SIGNING_SECRET=

# --- Base de datos (Neon Postgres; se crea a mitad de camino) ---
# La inyecta Vercel/Neon en .env.local. Ejecuta `node scripts/migrate.js` para crear la tabla.
DATABASE_URL=

# --- Cliente (Vite; deben empezar por VITE_ para exponerse al navegador) ---
# Proxy de Neon Auth del hub (mismas cuentas). Normalmente {HUB_URL}/api/auth
VITE_NEON_AUTH_URL=https://one-page-to-rule-them-all.vercel.app/api/auth
# URL base del hub para volver al terminar
VITE_HUB_URL=https://one-page-to-rule-them-all.vercel.app
